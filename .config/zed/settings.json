// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // ==========================================
  // 🧠 INTELLIGENCE ARTIFICIELLE & AGENTS
  // ==========================================
  "agent": {
    "default_profile": "write",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6",
    },
    "thread_summary_model": {
      "provider": "anthropic",
      "model": "claude-haiku-4-5-20251001",
    },
    "commit_message_model": {
      "provider": "anthropic",
      "model": "claude-haiku-4-5-20251001",
    },
  },
  "edit_predictions": {
    "provider": "copilot",
  },

  // ==========================================
  // 🎨 INTERFACE & APPARENCE
  // ==========================================
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Macchiato",
  },
  "icon_theme": "Material Icon Theme",
  "ui_font_family": "FiraCode Nerd Font",
  "ui_font_size": 16,
  "project_panel": {
    "dock": "left",
    "default_width": 240,
  },
  "notification_panel": {
    "button": false,
  },
  "collaboration_panel": {
    "button": false,
  },

  // ==========================================
  // ✍️ ÉDITEUR & COMPORTEMENT DE SAISIE
  // ==========================================
  "buffer_font_family": "FiraCode Nerd Font",
  "buffer_font_size": 15,
  "buffer_font_weight": 450,
  "buffer_font_features": {
    "calt": true,
  },
  "base_keymap": "VSCode",
  "cursor_blink": true,
  "always_treat_brackets_as_autoclosed": true,
  "sticky_scroll": {
    "enabled": true,
  },
  "minimap": {
    "show": "auto",
  },
  "inlay_hints": {
    "enabled": true,
  },
  "indent_guides": {
    "background_coloring": "disabled",
  },

  // ==========================================
  // 🧹 AUTOMATISATION, HYGIÈNE & DIAGNOSTICS
  // ==========================================
  "format_on_save": "on",
  "autosave": "on_focus_change",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "diagnostics": {
    "include_warnings": true,
  },

  // ==========================================
  // 🛠️ CONFIGURATION PAR LANGAGE
  // ==========================================
  "languages": {
    "Python": {
      "wrap_guides": [88],
      "language_servers": ["ruff", "pyright"],
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "ruff",
          "arguments": [
            "format",
            "--line-length",
            "88",
            "--stdin-filename",
            "{buffer_path}",
            "-",
          ],
        },
      },
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
      },
    },
    "Shell Script": {
      "wrap_guides": [80],
      "tab_size": 2,
      "soft_wrap": "none",
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "shfmt",
          "arguments": ["-i", "2", "-ci", "-bn", "-ln", "bash"],
        },
      },
    },
    "Markdown": {
      "format_on_save": "on",
      "soft_wrap": "preferred_line_length",
      "preferred_line_length": 120,
      "remove_trailing_whitespace_on_save": false,
    },
    "Rainbow CSV (;)": {
      "format_on_save": "off",
      "remove_trailing_whitespace_on_save": false,
    },
    "JSON": {
      "tab_size": 2,
      "format_on_save": "on",
    },
    "TOML": {
      "tab_size": 2,
      "format_on_save": "on",
    },
    "YAML": {
      "tab_size": 2,
      "format_on_save": "on",
    },
  },

  // ==========================================
  // 🚀 SERVEURS DE LANGAGE (LSP)
  // ==========================================
  "lsp": {
    "pyright": {
      "settings": {
        "python": {
          "analysis": {
            "typeCheckingMode": "basic",
            "autoImportCompletions": true,
            "diagnosticMode": "workspace",
          },
        },
      },
    },
    "ruff": {
      "settings": {
        "lineLength": 88,
        "lint": {
          "select": [
            "E", "W", "F", "I", "N", "UP", "B", "C90",
            "SIM", "RUF", "PTH", "PERF", "TRY", "LOG",
            "G", "ERA", "FBT", "PL", "D"
          ],
          "ignore": [
            "E501",   // line too long — handled by formatter
            "B008",   // function call in default arg (Typer/FastAPI)
            "D100",   // missing docstring in public module
            "D104",   // missing docstring in public package
            "D203",   // conflicts with D211
            "D213",   // conflicts with D212
            "TRY003"  // long messages outside exception class
          ],
          "fixable": ["ALL"]
        },
        "format": {
          "quoteStyle": "double",
          "indentStyle": "space",
          "lineEnding": "lf"
        }
      }
    },
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "format": { "enable": true },
          "schemaStore": { "enable": true },
          // Tags Python utilisés dans MkDocs — format correct : "!!tag type"
          // ATTENTION : inopérant tant que le bug yaml-language-server #1201 n'est
          // pas sorti en stable (scopeUri="null" empêche Zed de transmettre les settings).
          "customTags": [
            "!!python/name:pymdownx.superfences.fence_code_format scalar",
            "!!python/name:pymdownx.superfences.fence_div_format scalar",
            "!!python/name:material.extensions.emoji.twemoji scalar",
            "!!python/name:material.extensions.emoji.to_svg scalar",
          ],
        },
      },
    },
  },

  // ==========================================
  // 💻 TERMINAL & DEBUGGER
  // ==========================================
  "terminal": {
    "dock": "bottom",
    "font_family": "FiraCode Nerd Font",
    "font_size": 14,
    "max_scroll_history_lines": 10000,
    "copy_on_select": true,
  },
  "debugger": {
    "dock": "right",
  },
}
