# ────────────────────────────────────────────────────────────────────────
# Barre de titre
# ────────────────────────────────────────────────────────────────────────
# Par défaut, Kitty met à jour automatiquement le titre de la fenêtre.
# On désactive cette mise à jour pour laisser le shell contrôler le titre.
shell_integration no-title


# ────────────────────────────────────────────────────────────────────────
# Thème
# ────────────────────────────────────────────────────────────────────────
# Utilisation du thème Catppuccin-Macchiato (fichier externe)
include current-theme.conf


# ────────────────────────────────────────────────────────────────────────
# Police et Style
# ────────────────────────────────────────────────────────────────────────
# Police principale (Nerd Font pour icônes et ligatures)
font_family FiraCode Nerd Font

# Rediriger les glyphes Nerd Font (U+F000-U+F8FF) vers la version Mono
# Texte → FiraCode Nerd Font (icônes plus visibles)
# Icônes (Yazi, prompt, etc.) → FiraCode Nerd Font Mono (alignement parfait)
symbol_map U+F000-U+F8FF FiraCode Nerd Font Mono

# Style de la police
font_style Regular

# Taille de la police
font_size 12.0


# ────────────────────────────────────────────────────────────────────────
# Contrôle à distance
# ────────────────────────────────────────────────────────────────────────
# Activer le contrôle à distance pour les commandes 'kitty @'
allow_remote_control yes


# ────────────────────────────────────────────────────────────────────────
# Ligatures
# ────────────────────────────────────────────────────────────────────────
# Activer les ligatures si supportées par la police
enable_ligatures true


# ────────────────────────────────────────────────────────────────────────
# Dimensions initiales
# ────────────────────────────────────────────────────────────────────────
# Largeur et hauteur initiales de la fenêtre
initial_window_width 640
initial_window_height 400


# ────────────────────────────────────────────────────────────────────────
# Fond et Transparence
# ────────────────────────────────────────────────────────────────────────
# Transparence du fond (semi-transparent)
background_opacity 0.9

# Désactiver l'image de fond pour de meilleures performances
background_image none


# ────────────────────────────────────────────────────────────────────────
# Marges et Bordures
# ────────────────────────────────────────────────────────────────────────
# Largeur des marges autour des fenêtres
window_margin_width 5
single_windows_margin_width 0

# Largeur de la bordure
window_border_width 1pt

# Couleur de la bordure active
active_border_color #00ffff


# ────────────────────────────────────────────────────────────────────────
# Dispositions
# ────────────────────────────────────────────────────────────────────────
# Dispositions autorisées : colonne (Tall) et autres
enabled_layouts Tall, *


# ────────────────────────────────────────────────────────────────────────
# Barre d'onglets
# ────────────────────────────────────────────────────────────────────────
# Style de la barre d'onglets : Powerline
tab_bar_style powerline

# Style du Powerline : incliné
tab_powerline_style slanted

# Masquer la barre d’onglets si un seul onglet
tab_bar_min_tabs 2


# ────────────────────────────────────────────────────────────────────────
# Performances et confort
# ────────────────────────────────────────────────────────────────────────
# Utiliser le GPU pour le rendu
use_gpu yes

# Scrollback persistant et étendu
scrollback_lines 10000
scrollback_pager less


# ────────────────────────────────────────────────────────────────────────
# Raccourcis clavier
# ────────────────────────────────────────────────────────────────────────

### Navigation entre les fenêtres (panneaux)
map kitty_mod+( previous_window
map kitty_mod+) next_window

### Disposition des fenêtres
map kitty_mod+z toggle_layout stack

# Utiliser les numéros pour basculer rapidement entre les onglets
# (Essentiel pour la rapidité)
map ctrl+1 goto_tab 1
map ctrl+2 goto_tab 2
ma1p ctrl+3 goto_tab 3

### Lancement rapide d'applications
map ctrl+f11 new_tab btop
map ctrl+f12 new_tab yazi

### SSH dédié (kitten ssh)
map ctrl+f1 kitten ssh myserver

### Raccourcis pratiques (clipboard, URL, onglets)
map ctrl+shift+c copy_to_clipboard
map ctrl+shift+v paste_from_clipboard
map ctrl+shift+u open_url_with_default_program
map ctrl+shift+r set_tab_title

### SSH personnalisé (script externe)
map ctrl+f1 launch --type=tab --title "SSH to Remote Host" bash -c "~/.config/kitty/kittens/ssh_alpinelinux.sh"

