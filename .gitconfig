# ~/.gitconfig
# Configuration Git personnalisée

# ------------------------------------------------------------------------
# Identité de l'utilisateur
# ------------------------------------------------------------------------
[user]
    name  = Alan MARCHAND
    email = keltalan@proton.me

# ------------------------------------------------------------------------
# Initialisation des dépôts
# ------------------------------------------------------------------------
[init]
    defaultBranch = main

# ------------------------------------------------------------------------
# Éditeur par défaut
# ------------------------------------------------------------------------
[core]
    editor = zed --wait

# ------------------------------------------------------------------------
# Couleurs dans l'interface
# ------------------------------------------------------------------------
[color]
    ui = auto

[color "branch"]
    current = yellow reverse
    local   = yellow
    remote  = green

[color "status"]
    added     = green
    changed   = yellow
    untracked = red

[color "diff"]
    meta = yellow
    frag = magenta
    old  = red
    new  = green

# ------------------------------------------------------------------------
# Push, pull et fetch
# ------------------------------------------------------------------------
[push]
    autoSetupRemote = true   # Configure automatiquement le tracking lors d'un premier push

[pull]
    rebase = false           # Utilise un merge (plus explicite, recommandé pour les débutants)

[fetch]
    prune = true             # Supprime automatiquement les branches distantes obsolètes

# ------------------------------------------------------------------------
# Qualité des diffs
# ------------------------------------------------------------------------
[diff]
    algorithm = histogram    # Meilleur algorithme : plus lisible sur les refactorings

# ------------------------------------------------------------------------
# Rebase et résolution de conflits
# ------------------------------------------------------------------------
[rebase]
    autosquash = true        # Place automatiquement les commits fixup!/squash! au bon endroit

[rerere]
    enabled = true           # Mémorise et rejoue automatiquement les résolutions de conflits

# ------------------------------------------------------------------------
# Affichage des branches et logs
# ------------------------------------------------------------------------
[branch]
    sort = -committerdate    # Branches triées par date du dernier commit

[log]
    date = format:%Y-%m-%d %H:%M

# ------------------------------------------------------------------------
# Alias pratiques
# ------------------------------------------------------------------------
[alias]
    # Commandes courtes
    st      = status -sb
    co      = checkout
    ci      = commit
    br      = branch
    d       = diff
    ds      = diff --staged
    undo    = reset --soft HEAD~1
    po      = push origin HEAD

    # Historique graphique
    lg      = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%ar) %C(bold blue)<%an>%Creset' --abbrev-commit --all
    gl10    = log -10 --oneline --decorate
    glast   = log -1 HEAD

    # Gestion des branches
    gcb     = checkout -b
    gbd     = branch -d
    gbD     = branch -D

    # Stash
    gsta    = stash
    gstp    = stash pop

    # Nettoyage
    gunstage = reset HEAD --
    gcleanup = "!git branch --merged | grep -v '\\*' | xargs git branch -d"
    gprune   = "!git remote prune origin"

# ------------------------------------------------------------------------
# Configuration locale (email pro, clé GPG, etc.) — non versionné
# ------------------------------------------------------------------------
[include]
    path = ~/.gitconfig.local
